# Entra ID (Azure AD) settings - Local Development
# Replace {initial_domain_name or organization_id} and {your_spa_client_id} and {your_api_client_id} with your actual values
VITE_OIDC_AUTHORITY=https://{initial_domain_name or organization_id}.ciamlogin.com/{initial_domain_name or organization_id}.onmicrosoft.com/v2.0
VITE_OIDC_CLIENT_ID={your_spa_client_id}
VITE_OIDC_REDIRECT_URI=http://localhost:5173
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
VITE_OIDC_SCOPE=openid profile email
